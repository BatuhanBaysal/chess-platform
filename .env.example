# --- Chess Platform Environment Variables Example ---

# Database Configuration
CHESS_DB_URL=jdbc:postgresql://localhost:5432/your_db_here
CHESS_DB_USERNAME=your_username_here
CHESS_DB_PASSWORD=your_password_here

# JWT Authentication
# Use a strong, randomly generated 256-bit key (hex encoded)
CHESS_JWT_SECRET=your_jwt_secret_here
CHESS_JWT_EXPIRATION=86400000

# SonarQube Configuration
SONAR_DB_USER=your_sonar_db_user_here
SONAR_DB_PASSWORD=your_sonar_db_password_here
SONAR_DB_NAME=your_sonar_db_name_here
SONAR_TOKEN=your_sonar_token_here
